// WordPool schema — community flashcard app
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  passHash   String
  createdAt  DateTime    @default(now())
  savedTests SavedTest[]
}

model SavedTest {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  deckId    Int
  cardIds   String // JSON array of card ids
  createdAt DateTime @default(now())
}

model Deck {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  level      String? // null | "Basic" | "Intermediate" | "Advanced"
  sourceLang String? // word language code, e.g. "en-US" (the "From")
  targetLang String? // meaning language code, e.g. "vi-VN"; null => Vietnamese
  createdAt  DateTime @default(now())
  cards      Card[]
}

model Card {
  id          Int      @id @default(autoincrement())
  word        String
  meaning     String
  explanation String?
  ipa         String?
  authorName  String
  color       String   @default("#ffffff")
  lang        String   @default("en-US")
  createdAt   DateTime @default(now())
  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  deckId      Int
}
